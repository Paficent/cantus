{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cantus",
  "version": "0.1.0",
  "identifier": "com.paficent.cantus",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cantus",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDMjVDQzYyQ0Q0QzQ5MDYKUldRR1NVek5Zc3dsN0M4WGxYcWNHOUNhalhZbG5JNERYdjdKRVdMT3RsbkwrY1c0bjExVk1mZ1UK",
      "endpoints": [
        "https://github.com/Paficent/cantus/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
